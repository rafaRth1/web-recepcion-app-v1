{
   "plugins": ["prettier-plugin-tailwindcss"],
   "semi": true,
   "trailingComma": "es5",
   "singleQuote": false,
   "endOfLine": "lf",
   "printWidth": 130,
   "tabWidth": 3,
   "useTabs": true,
   "arrowParens": "always",
   "bracketSpacing": true,
   "jsxSingleQuote": false,
   "parser": "typescript"
}
